%comments are written in % we will create a simple script to forecast 10 days, C-loudy, S-unny, R-ainy
%define Matrix of probability and starter vector x
A=[0.5 0.5 0.25;0.25 0 0.25;0.25 0.5 0.5]
x=[1 0 0]
x_today=x' %this will create column vector 3x1
% A = 3x3, more states more elements for nxn dimensions

%start forecast 10 days
for i = 0:10
	x_tomorrow=A*x_today
	x_today=x_tomorrow
end
